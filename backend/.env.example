# =============================================================================
#  IntZam LMS — Environment Variable Reference
#  This file IS committed to git (no real secrets here).
#  Copy to .env.local and fill in your values to get started.
# =============================================================================

APP_ENV=production

# Django
SECRET_KEY=                                        # generate: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DEBUG=False
ALLOWED_HOSTS=api.yourdomain.com,yourdomain.com
# PostgreSQL
DATABASE_URL=postgres://intzam_user:password@db:5432/intzam_lms
CORS_ALLOWED_ORIGINS=https://admin.yourdomain.com,https://client.yourdomain.com

# AI
GEMINI_API_KEY=

# Odoo 17 connection
ODOO_URL=http://localhost:8069
ODOO_DB=odoo_lms_test
ODOO_USER=admin
ODOO_PASSWORD=
ODOO_ENABLED=true

# Odoo journals
ODOO_JOURNAL_DISBURSEMENT=LDIS
ODOO_JOURNAL_REPAYMENT=LRPY
ODOO_JOURNAL_INTEREST=LINT
ODOO_JOURNAL_FEES=LFEE
ODOO_JOURNAL_PROVISION=LPROV

# Odoo accounts
ODOO_ACCOUNT_BANK_CLEARING=1105
ODOO_ACCOUNT_LOAN_REC_S1=1111
ODOO_ACCOUNT_LOAN_REC_S2=1112
ODOO_ACCOUNT_LOAN_REC_S3=1113
ODOO_ACCOUNT_INTEREST_REC=1120
ODOO_ACCOUNT_PENALTY_REC=1121
ODOO_ACCOUNT_PROV_S1=1201
ODOO_ACCOUNT_PROV_S2=1202
ODOO_ACCOUNT_PROV_S3=1203
ODOO_ACCOUNT_INTEREST_INCOME_S1=4101
ODOO_ACCOUNT_PENALTY_INCOME=4202
ODOO_ACCOUNT_ORIGINATION_FEE=4201
ODOO_ACCOUNT_RECOVERY=4302
ODOO_ACCOUNT_PROV_EXP_S1=5101
ODOO_ACCOUNT_PROV_EXP_S2=5102
ODOO_ACCOUNT_PROV_EXP_S3=5103
ODOO_ACCOUNT_WRITEOFF_EXP=5104
ODOO_ACCOUNT_MOMO_LEVY=2109

# ── Konse Konse (*543#) Payment Gateway ───────────────────────────────────────
# NOTE: COA accounts 1106 (Bank USD Account) and 2110 (Lease Liability Current)
# are already in use in this Odoo instance.  The four KK-specific COA accounts
# are therefore 1107 / 1108 / 2111 / 5223 — not 1106/2110 as the original
# setup guide suggested.
KONSE_BASE_URL=https://sandbox.konsepay.com
KONSE_API_KEY=
KONSE_SECRET=
KONSE_SANDBOX=true
KONSE_WEBHOOK_SECRET=
KONSE_CALLBACK_URL=https://YOUR_NGROK.ngrok.io/api/accounting/konse-webhook/
KONSE_POLLING_INTERVAL_SECONDS=30
KONSE_MAX_RETRIES=3
KONSE_SHORTCODE=*543#

# Email
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=noreply@intzam.local
