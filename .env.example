# =============================================================================
#  IntZam LMS — Docker Compose Production Variables
#
#  Copy this file to .env and fill in every value:
#      cp .env.example .env
#
#  This file is read by docker-compose.prod.yml at startup.
#  NEVER commit .env with real secrets.
# =============================================================================

# ── PostgreSQL (shared DB server) ─────────────────────────────────────────────
# Strong password for the intzam_user database account.
# Generate: openssl rand -base64 32
DB_PASSWORD=CHANGE_ME_strong_db_password

# ── Frontend build-time API URL ───────────────────────────────────────────────
# The URL browsers use to reach your backend API.
# Example: https://yourdomain.com/api
VITE_API_URL=https://CHANGE_ME_yourdomain.com/api
