# =============================================================================
#  IntZam Website CMS — PRODUCTION ENVIRONMENT
#  Fill in every value before deploying. Never commit with real secrets.
# =============================================================================

DEBUG=False

# CHANGE: Generate with: python -c "import secrets; print(secrets.token_urlsafe(50))"
WEBSITE_SECRET_KEY=CHANGE_ME_generate_with_python_secrets

# CHANGE: Your server domain(s), comma-separated
ALLOWED_HOSTS=CHANGE_ME_yourdomain.com,www.CHANGE_ME_yourdomain.com

# PostgreSQL — uses same DB host as backend but a separate database
# Format: postgres://USER:PASSWORD@HOST:PORT/DBNAME
WEBSITE_DATABASE_URL=postgres://intzam_user:CHANGE_ME_db_password@db:5432/intzam_website
